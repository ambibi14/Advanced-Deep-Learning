        "def compute_mean_std(array):\n",
        "    \"\"\"Computes mean and standard deviation of a flattened awkward array.\"\"\"\n",
        "    flat = awkward.flatten(array)\n",
        "    mean = np.mean(flat)\n",
        "    std = np.std(flat)\n",
        "    return mean, std\n",
        "\n",
        "def normalize(array, mean, std):\n",
        "    \"\"\"Normalizes an awkward array using given mean and standard deviation.\"\"\"\n",
        "    return (array - mean) / std"
