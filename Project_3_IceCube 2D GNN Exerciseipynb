        "import torch_geometric.data # Ensure torch_geometric.data.Batch is available\n",
        "\n",
        "# CUSTOM AWKWARD DATASET CLASS\n",
        "\n",
        "\n",
        "class AwkwardDataset(torch.utils.data.Dataset):\n",
        "    \"\"\"Custom PyTorch Dataset for handling Awkward Arrays.\"\"\"\n",
        "    def __init__(self, awkward_array):\n",
        "        self.awkward_array = awkward_array\n",
        "\n",
        "    def __len__(self):\n",
        "        \"\"\"Returns the total number of samples in the dataset.\"\"\"\n",
        "        return len(self.awkward_array)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        \"\"\"Retrieves a single sample (awkward record) by index.\"\"\"\n",
        "        return self.awkward_array[idx]\n",
        "\n",
        "\n",
        "# CUSTOM COLLABORATE FUNCTION FOR GNN\n",
        "\n",
        "\n",
        "def collate_fn_gnn(batch):\n",
        "    \"\"\"Collate function to convert a batch of awkward records into PyG Batch objects.\"\"\"\n",
        "    data_list = [] # List to store PyG Data objects\n",
        "    labels = [] # List to store labels (target positions)\n",
        "\n",
        "    for b in batch:\n",
        "        # Convert hit data (time, x, y) to PyTorch tensor and transpose\n",
        "        tensor_data = torch.from_numpy(\n",
        "            b[\"data\"].to_numpy()\n",
        "        ).T\n",
        "\n",
        "        # Ensure data type is float32\n",
        "        tensor_data = tensor_data.to(dtype=torch.float32)\n",
        "\n",
        "        # Create a PyTorch Geometric Data object for the graph\n",
        "        graph = torch_geometric.data.Data(x=tensor_data)\n",
        "\n",
        "        data_list.append(graph)\n",
        "\n",
        "        # Create a tensor for the xpos and ypos labels\n",
