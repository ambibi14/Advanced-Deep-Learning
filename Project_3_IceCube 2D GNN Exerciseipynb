        "# GNN MODEL DEFINITION (GNNEncoder)\n",
        "\n",
        "\n",
        "class GNNEncoder(nn.Module):\n",
        "    \"\"\"Graph Neural Network Encoder for neutrino interaction reconstruction.\"\"\"\n",
        "\n",
        "    def __init__(self, k=8): # k: number of nearest neighbors for DynamicEdgeConv\n",
        "\n",
        "        super().__init__()\n",
        "\n",
        "        # First DynamicEdgeConv layer\n",
        "        self.layer1 = DynamicEdgeConv(\n",
        "            nn=make_mlp(\n",
        "                input_dim=6,    # Input dimension (2 * features per node: 2 * 3 = 6 for edge conv)\n",
        "                hidden_dim=64,\n",
        "                output_dim=64\n",
        "            ),\n",
        "            k=k,\n",
        "            aggr='mean' # Aggregation method for edge features\n",
        "        )\n",
        "\n",
        "        # Second DynamicEdgeConv layer\n",
        "        self.layer2 = DynamicEdgeConv(\n",
        "            nn=make_mlp(\n",
        "                input_dim=128, # Input dimension (2 * output from layer1 = 2 * 64 = 128)\n",
        "                hidden_dim=128,\n",
        "                output_dim=128\n",
        "            ),\n",
        "            k=k,\n",
        "            aggr='mean'\n",
        "        )\n",
        "\n",
        "        # Third DynamicEdgeConv layer\n",
        "        self.layer3 = DynamicEdgeConv(\n",
        "            nn=make_mlp(\n",
        "                input_dim=256, # Input dimension (2 * output from layer2 = 2 * 128 = 256)\n",
        "                hidden_dim=128,\n",
        "                output_dim=128\n",
        "            ),\n",
        "            k=k,\n",
        "            aggr='mean'\n",
        "        )\n",
        "\n",
        "        # Final Multi-Layer Perceptron for regression output\n",
        "        self.final_mlp = nn.Sequential(\n",
        "            nn.Linear(128, 64), # Reduce dimensions\n",
        "            nn.ReLU(),\n",
        "\n",
        "            nn.Linear(64, 32),\n",
        "            nn.ReLU(),\n",
        "\n",
        "            nn.Linear(32, 2) # Output 2 values (x, y positions)\n",
        "        )\n",
        "\n",
        "    def forward(self, data):\n",
        "        \"\"\"Forward pass of the GNN model.\"\"\"\n",
        "        x = data.x      # Node features\n",
        "        batch = data.batch # Batch assignment for each node\n",
        "\n",
