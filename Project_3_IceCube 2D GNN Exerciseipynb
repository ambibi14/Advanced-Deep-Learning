        "## Hyperparameter Tuning with Optuna\n",
        "\n",
        "We will use Optuna to perform hyperparameter tuning for our GNN model. Optuna is an automatic hyperparameter optimization framework, which can find optimal hyperparameter values efficiently.\n",
        "\n",
        "We will define an `objective` function that takes a trial object and suggests hyperparameters like learning rate and `k_neighbors`. The function will then train and evaluate the model using these suggested hyperparameters and return the validation MAE to Optuna for optimization."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "8Oy6-AbzH-ZF"
      },
      "source": [
        "# Install Optuna if not already installed (for hyperparameter tuning)\n",
        "!pip install optuna"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "VvChkJEGIBOm"
      },
      "source": [
        "import optuna # Import Optuna library\n",
        "\n",
        "def objective(trial):\n",
        "    \"\"\"Objective function for Optuna hyperparameter tuning.\"\"\"\n",
        "    # Hyperparameters to tune: learning rate (log-uniform distribution)\n",
        "    learning_rate = trial.suggest_loguniform('learning_rate', 1e-4, 1e-2)\n",
        "    # Hyperparameters to tune: k_neighbors (integer range)\n",
        "    k_neighbors = trial.suggest_int('k_neighbors', 4, 16)\n",
        "\n",
        "    # Re-initialize model, optimizer, and criterion for each trial\n",
        "    # The GNNEncoder's k parameter is set by k_neighbors suggested by Optuna\n",
        "    model = GNNEncoder(k=k_neighbors).to(DEVICE)\n",
        "    optimizer = optim.Adam(model.parameters(), lr=learning_rate) # Optimizer with suggested learning rate\n",
        "    criterion = nn.MSELoss() # Loss function\n",
        "\n",
        "    # Training loop for this trial (fewer epochs for tuning to save time)\n",
        "    NUM_TUNING_EPOCHS = 10 # Reduced epochs for faster tuning\n",
        "    best_val_mae = float('inf') # Initialize best validation MAE\n",
        "\n",
        "    for epoch in range(NUM_TUNING_EPOCHS):\n",
        "        model.train()\n",
        "        for graphs, labels in train_loader:\n",
        "            graphs = graphs.to(DEVICE)\n",
        "            labels = labels.to(DEVICE)\n",
        "            optimizer.zero_grad()\n",
        "            predictions = model(graphs)\n",
        "            loss = criterion(predictions, labels)\n",
        "            loss.backward()\n",
        "            optimizer.step()\n",
        "\n",
        "        # Evaluate on validation set\n",
        "        model.eval()\n",
        "        val_loss, val_mae, _, _ = evaluate(val_loader)\n",
        "\n",
        "        # Report intermediate objective value to Optuna for pruning\n",
        "        trial.report(val_mae, epoch)\n",
        "\n",
        "        # Handle pruning based on the intermediate value (stop unpromising trials early)\n",
        "        if trial.should_prune():\n",
        "            raise optuna.exceptions.TrialPruned()\n",
        "\n",
        "    return val_mae # Return the final validation MAE for this trial"
      ],
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "E9uIct3CIEO2"
      },
      "source": [
        "# Create an Optuna study and optimize\n",
        "# 'direction=\"minimize\"' indicates that we want to find the parameters that yield the minimum objective value (MAE)\n",
        "study = optuna.create_study(direction='minimize')\n",
        "# Run the optimization process for a specified number of trials (e.g., 20)\n",
        "study.optimize(objective, n_trials=20)\n",
        "\n",
        "print(\"Number of finished trials: \", len(study.trials))\n",
        "print(\"Best trial:\")\n",
        "trial = study.best_trial # Get the trial with the best objective value\n",
        "\n",
        "print(\"  Value: \", trial.value) # Print the best objective value (MAE)\n",
        "print(\"  Params: \")\n",
        "# Print the hyperparameters of the best trial\n",
        "for key, value in trial.params.items():\n",
        "    print(f\"    {key}: {value}\")\n",
        "\n",
        "# You can also access the best parameters directly\n",
        "best_learning_rate = study.best_params['learning_rate']\n",
        "best_k_neighbors = study.best_params['k_neighbors']\n",
        "\n",
        "print(f\"\\nBest learning rate: {best_learning_rate}\")\n",
