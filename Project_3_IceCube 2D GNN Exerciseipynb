        "\n",
        "def normalize_dataset(dataset):\n",
        "    \"\"\"Applies normalization to the dataset's hit features and target positions.\"\"\"\n",
        "    # Extract hit features\n",
        "    times = dataset[\"data\"][:, 0:1, :]\n",
        "    x_hits = dataset[\"data\"][:, 1:2, :]\n",
        "    y_hits = dataset[\"data\"][:, 2:3, :]\n",
        "\n",
        "    # Normalize hit features\n",
        "    norm_times = normalize(times, time_mean, time_std)\n",
        "    norm_x = normalize(x_hits, x_mean, x_std)\n",
        "    norm_y = normalize(y_hits, y_mean, y_std)\n",
        "\n",
        "    # Concatenate normalized hit features back into 'data' field\n",
        "    dataset[\"data\"] = awkward.concatenate(\n",
        "        [norm_times, norm_x, norm_y],\n",
        "        axis=1\n",
        "    )\n",
        "\n",
        "    # Normalize target x-position\n",
        "    dataset[\"xpos\"] = normalize(\n",
        "        dataset[\"xpos\"],\n",
        "        xpos_mean,\n",
        "        xpos_std\n",
        "    )\n",
        "\n",
        "    # Normalize target y-position\n",
        "    dataset[\"ypos\"] = normalize(\n",
        "        dataset[\"ypos\"],\n",
        "        ypos_mean,\n",
        "        ypos_std\n",
        "    )\n",
        "\n",
        "    return dataset\n",
